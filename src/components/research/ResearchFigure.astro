---
/**
 * Editorial figure shell for phase4 / phase5 PNGs that aren't being
 * redrawn as SVG. Provides the same chrome (dark plate, mono labels,
 * italic Literata caption) as SlopeChart so typography unifies even
 * when the underlying plot was generated by matplotlib.
 */

interface Props {
  src: string;
  alt: string;
  num: string;
  title: string;
  caption?: string;
  source?: string;
  id?: string;
}

const { src, alt, num, title, caption, source, id } = Astro.props;
---

<figure class="research-figure" id={id}>
  <div class="figure-eyebrow">
    <span class="fig-num">{num}</span>
    <span>{title}</span>
  </div>

  {caption && <p class="figure-deck">{caption}</p>}

  <div class="figure-plate plate-img">
    <img src={src} alt={alt} loading="lazy" />
  </div>

  {source && <figcaption class="figure-source">{source}</figcaption>}
</figure>
