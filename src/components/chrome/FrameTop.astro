---
interface Props {
  /** When true, section anchors (#paths, #curriculum, …) are in-page links.
   *  When false (lesson pages), they prepend a "/" to navigate back to the
   *  landing page first. */
  onLanding?: boolean;
}

const { onLanding = false } = Astro.props;
const prefix = onLanding ? '' : '/';

const navItems = [
  { label: 'Paths', href: `${prefix}#paths` },
  { label: 'Curriculum', href: `${prefix}#curriculum` },
  { label: 'Workshops', href: `${prefix}#workshops` },
  { label: 'Exhibition', href: `${prefix}#exhibition` },
  // Research nav scrolls to the §5 teaser on the landing page rather than
  // jumping straight to /research. The teaser ends in a "Read the full
  // study →" CTA that takes the visitor to /research deliberately.
  { label: 'Research', href: `${prefix}#research` },
];
