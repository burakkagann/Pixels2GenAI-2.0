<script>
  const SESSION_KEY = 'p2g-octo-greeted';
  const octo = document.querySelector('.octo') as HTMLElement | null;
  if (octo) {
    // First arrival per session: play the wave once
    if (!sessionStorage.getItem(SESSION_KEY)) {
      octo.classList.add('octo--play');
      sessionStorage.setItem(SESSION_KEY, '1');
    }
    // Hover always replays — remove then re-add to restart the animation
    octo.addEventListener('mouseenter', () => {
      octo.classList.remove('octo--play');
      void octo.offsetWidth; // force reflow so the animation restarts cleanly
      octo.classList.add('octo--play');
    });
  }

  // Theme toggle — binary light/dark. The no-flash <script is:inline> in
  // Base.astro <head> sets data-theme on first paint; this just flips it
  // on click and persists the user's explicit choice to localStorage.
  const toggle = document.querySelector('.theme-toggle') as HTMLButtonElement | null;
  const STORAGE_KEY = 'p2g-theme';

  const syncToggleState = (theme: string) => {
    if (!toggle) return;
    const isLight = theme === 'light';
    toggle.setAttribute('aria-pressed', String(isLight));
    toggle.setAttribute(
      'aria-label',
      isLight ? 'Switch to dark theme' : 'Switch to light theme',
    );
  };

  syncToggleState(document.documentElement.getAttribute('data-theme') ?? 'dark');

  toggle?.addEventListener('click', () => {
    const current = document.documentElement.getAttribute('data-theme') ?? 'dark';
    const next = current === 'light' ? 'dark' : 'light';
    document.documentElement.setAttribute('data-theme', next);
    try { localStorage.setItem(STORAGE_KEY, next); } catch {}
    syncToggleState(next);
    document.dispatchEvent(new CustomEvent('themechange', { detail: { theme: next } }));
  });
</script>
