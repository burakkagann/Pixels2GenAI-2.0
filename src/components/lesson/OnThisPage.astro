---
/**
 * Right-rail "On this page" TOC, redesigned as the toc-card.
 * Carries the cycle accent via a chip + the active heading "you-are-here"
 * beacon. Scroll-spy toggles `.cur` on the <li> so the border + tint
 * fill drive the cycle accent.
 */

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
  slug: string;
  cycle: 'I' | 'II' | 'III';
}

const { headings, slug, cycle } = Astro.props;

// Keep h2 and h3 only — h1 is the lesson title, h4+ is too granular.
const tocItems = headings.filter(h => h.depth === 2 || h.depth === 3);

const cycleNames: Record<Props['cycle'], string> = {
  'I':   'i · foundations',
  'II':  'ii · continuum',
  'III': 'iii · generative',
};
---

<nav class="toc-card" aria-label="On this page">
  <div class="head">
    <h4>On this page</h4>
    <span class="ix">§ {slug}</span>
  </div>
  <div class="cycle-chip">
    <span class="cyc-dot" aria-hidden="true"></span>
    <span>Cycle</span><b>{cycleNames[cycle]}</b>
  </div>
  <ul>
    {tocItems.map(h => (
      <li class={h.depth === 2 ? 'l2' : 'l3'}>
        <a href={`#${h.slug}`} data-toc-slug={h.slug}>{h.text}</a>
      </li>
    ))}
  </ul>
</nav>

<script>
  // Scroll-spy: toggle .cur on the <li> (not the <a>) so the beacon's
  // left-border + tint background carry the cycle accent. Keeps the
  // markup minimal and the styling fully CSS-driven.
  const links = Array.from(document.querySelectorAll<HTMLAnchorElement>('.toc-card a[data-toc-slug]'));
  const lis = links.map(a => a.closest('li')!).filter(Boolean);
  const sections = links
    .map((a, i) => ({ li: lis[i], el: document.getElementById(a.dataset.tocSlug!) }))
    .filter((s): s is { li: HTMLElement; el: HTMLElement } => !!s.el);

  if (sections.length) {
    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter(e => e.isIntersecting)
          .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
        if (!visible.length) return;
        const topEl = visible[0].target as HTMLElement;
        lis.forEach(li => li.classList.remove('cur'));
        const match = sections.find(s => s.el === topEl);
        if (match) match.li.classList.add('cur');
      },
      { rootMargin: '-80px 0px -70% 0px', threshold: 0 },
    );
    sections.forEach(s => observer.observe(s.el));
  }
</script>
